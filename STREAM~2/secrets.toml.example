# ===================================================================
#  قالب إعدادات الأسرار (Secrets)
#  انسخ محتوى هذا الملف والصقه في:
#  Streamlit Cloud → تطبيقك → Settings → Secrets
#  محلياً: أنشئ ملف .streamlit/secrets.toml (لا يُرفع إلى GitHub) والصق فيه.
# ===================================================================

# --- 1) رقم واتساب الأعمال (بدون +) ---
[contact]
whatsapp_number = "966533665005"

# --- 2) كلمة مرور لوحة التحكم — غيّرها إلى كلمة قوية ---
[admin]
password = "ضع_كلمة_مرور_قوية_هنا"

# --- 3) جدول Google Sheets لحفظ الطلبات ---
[sheets]
# المفتاح هو الجزء بين /d/ و /edit في رابط جدولك
spreadsheet_key = "الصق_مفتاح_الجدول_هنا"

# --- 4) بيانات حساب خدمة Google (من ملف JSON الذي نزّلته) ---
[gcp_service_account]
type = "service_account"
project_id = "..."
private_key_id = "..."
# انتبه: اترك \n داخل المفتاح كما هي نصاً ولا تحوّلها إلى أسطر فعلية
private_key = "-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
client_email = "...@....iam.gserviceaccount.com"
client_id = "..."
auth_uri = "https://accounts.google.com/o/oauth2/auth"
token_uri = "https://oauth2.googleapis.com/token"
auth_provider_x509_cert_url = "https://www.googleapis.com/oauth2/v1/certs"
client_x509_cert_url = "..."
universe_domain = "googleapis.com"
